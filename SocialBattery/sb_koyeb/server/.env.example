SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...
SUPABASE_ANON_KEY=eyJ...
PORT=3001
CLIENT_URL=http://localhost:5173

# Web Push (notificaciones moviles)
# Genera tu par de claves con:
#   node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(k);"
# El cliente puede leer VAPID_PUBLIC_KEY en runtime desde /api/users/push-config.
# Si el frontend se construye/depliega aparte, pon el mismo valor como
# VITE_VAPID_PUBLIC_KEY durante el build del cliente.
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_SUBJECT=mailto:admin@yourdomain.com
