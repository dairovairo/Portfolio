VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
VITE_API_URL=http://localhost:3001/api
# Opcional si el cliente y backend comparten despliegue: si falta, el cliente
# la pide en runtime a /api/users/push-config.
# Si el frontend se despliega estatico aparte, debe coincidir con
# VAPID_PUBLIC_KEY del server (ver server/.env.example).
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here
